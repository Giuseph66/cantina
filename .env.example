# ─── API ───────────────────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/cantina.db"
PORT=3000
NODE_ENV=development
APP_PUBLIC_URL="http://localhost:3000"

# JWT
JWT_SECRET="CHANGE_ME_IN_PRODUCTION_USE_LONG_RANDOM_STRING"
JWT_EXPIRES_IN="8h"

# CORS
CORS_ORIGIN="http://localhost:5173"

# Webhook PIX — defina o mesmo secret configurado no provedor de pagamento
WEBHOOK_PIX_SECRET="CHANGE_ME_WEBHOOK_SECRET"
