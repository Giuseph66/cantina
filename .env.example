# ─── API ───────────────────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/cantina.db"
PORT=3000
NODE_ENV=development
APP_PUBLIC_URL="http://localhost:3000"

# JWT
JWT_SECRET="CHANGE_ME_IN_PRODUCTION_USE_LONG_RANDOM_STRING"
JWT_EXPIRES_IN="8h"

# CORS
CORS_ORIGIN="http://localhost:5173"

# Google Auth
GOOGLE_WEB_CLIENT_ID=""

# Pagamentos online
PIX_THRESHOLD=80
MP_ACCESS_TOKEN_SANDBOX=""
MP_PUBLIC_KEY_SANDBOX=""
MP_ACCESS_TOKEN_PRODUCTION=""
MP_PUBLIC_KEY_PRODUCTION=""
ABACATEPAY_API_KEY_SANDBOX=""
ABACATEPAY_API_KEY_PRODUCTION=""

# Webhooks
WEBHOOK_SHARED_SECRET="CHANGE_ME_WEBHOOK_SECRET"
ABACATEPAY_PUBLIC_HMAC_KEY=""
MP_WEBHOOK_SECRET=""
MP_WEBHOOK_SECRET_SANDBOX=""
MP_WEBHOOK_SECRET_PRODUCTION=""
PAYMENT_RECONCILIATION_BATCH_SIZE=20
